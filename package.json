{
  "name": "block-headers-client",
  "private": false,
  "version": "1.1.4",
  "description": "A typescript bitcoin sv block headers client",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/api",
    "README.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "rimraf dist && rimraf docs && tsc",
    "test": "vitest --exclude=tests/BlockHeadersClient.spec.ts --no-watch",
    "test:coverage": "vitest --exclude=tests/BlockHeadersClient.spec.ts --no-watch --coverage",
    "test:connections": "vitest run tests/BlockHeadersClient.spec.ts --passWithNoTests --sequence.concurrent=false --no-watch",
    "prepublishOnly": "npm run build",
    "start-nobuild": "node --env-file=.env dist/api/index.js",
    "start-build": "npm run build && npm run start-nobuild"
  },
  "keywords": [
    "bitcoin",
    "bsv",
    "blockchain"
  ],
  "author": "matrm <matrm@gmx.com>",
  "license": "SEE LICENSE IN LICENSE.txt",
  "dependencies": {
    "level": "^10.0.0",
    "red-black-map": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matrm/block-headers-client-ts.git"
  },
  "bugs": {
    "url": "https://github.com/matrm/block-headers-client-ts/issues"
  },
  "homepage": "https://github.com/matrm/block-headers-client-ts#readme"
}
